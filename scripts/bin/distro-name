#! /usr/bin/env bash
# Termux
if [[ -n "$TERMUX_VERSION" ]]; then
    ver=$(getprop ro.build.version.release 2>/dev/null)
    codename=$(getprop ro.build.version.codename 2>/dev/null)

    echo "Android ${codename} ${ver} $(uname -m)"

# 通常のLinux
elif [[ -r /etc/os-release ]]; then
    source /etc/os-release
    echo "${PRETTY_NAME:-$NAME}"

else
    echo "$(uname -s)"
fi
