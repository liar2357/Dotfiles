#!/usr/bin/env bash

pgrep -f autoreroad-waybar | grep -v $$ >/dev/null && exit

HOSTNAME=$(hostname)

WATCH_DIR="$HOME/Dotfiles/hosts/$HOSTNAME/waybar"

CONFIG_TOP="$WATCH_DIR/top.jsonc"
CONFIG_BOTTOM="$WATCH_DIR/bottom.jsonc"
STYLE="$WATCH_DIR/style.css"

source $HOME/Dotfiles/scripts/app/waybar-boot-and-reload.sh

waybar-boot-and-reload "$@"
