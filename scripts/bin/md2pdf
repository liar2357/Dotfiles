#!/usr/bin/env bash

# md2pdf: Markdown → PDF (Pandoc + Typst)

set -euo pipefail

usage() {
	echo "Usage"
	echo "====="
	echo "md2pdf init                Generate template.md"
	echo "md2pdf fonts               Generate fonts.conf"
	echo "md2pdf conv <input.md>     Convert Markdown to PDF"
	echo "====="
}

if [[ $# -lt 1 ]]; then
	usage
	exit 1
fi

case "$1" in
init)
	TEMPLATE="$HOME/.config/md2pdf/template.md"

	if [[ ! -f "$TEMPLATE" ]]; then
		echo "Template not found: $TEMPLATE"
		exit 1
	fi

	install -m 644 "$TEMPLATE" "./template.md"

	echo "template.md generated"
	;;

fonts)
	FONT_DIR="$HOME/.config/md2pdf/fonts"

	configs=("$FONT_DIR"/*)

	echo "Select font config"
	echo "=================="

	for i in "${!configs[@]}"; do
		printf "%2d) %s\n" \
			"$((i + 1))" \
			"$(basename "${configs[$i]}")"
	done

	echo

	while true; do
		read -rp "Number: " choice

		# 数値チェック
		if [[ ! "$choice" =~ ^[0-9]+$ ]]; then
			echo "Please enter a number."
			continue
		fi

		# 範囲チェック
		if ((choice < 1 || choice > ${#configs[@]})); then
			echo "Out of range."
			continue
		fi

		CONFIG="${configs[$((choice - 1))]}"
		break
	done

	echo "Selected: $(basename "$CONFIG")"
	echo

	install -m 644 "$CONFIG" "./fonts.conf"
	echo "fonts.conf generated"

	;;

conv)
	if [[ $# -lt 2 ]]; then
		usage
		exit 1
	fi

	INPUT="$2"

	if [[ ! -f "$INPUT" ]]; then
		echo "Input file not found: $INPUT"
		exit 1
	fi

	CONFIG="fonts.conf"

	if [[ -f "$CONFIG" ]]; then
		echo "====="
		echo "Load font config"
		echo "====="

		# shellcheck disable=SC1090
		source "$CONFIG"
	else
		echo "====="
		echo "Font config is not exists"
		echo "Fall back to default font config"
		echo "====="

		MAINFONT="Noto Serif CJK JP"
		SANSFONT="Noto Sans CJK JP"
		MONOFONT="Noto Sans Mono CJK JP"
		FONTSIZE="11pt"
	fi

	BASE="$(basename "$INPUT" .md)"
	OUT="${BASE}.pdf"

	pandoc "$INPUT" \
		--pdf-engine=typst \
		-V template=@local/MDTemp:1.0.0 \
		-M mainfont="$MAINFONT" \
		-M sansfont="$SANSFONT" \
		-M monofont="$MONOFONT" \
		-M fontsize="$FONTSIZE" \
		-o "$OUT"

	echo "PDF generated: $OUT"
	;;

*)
	usage
	exit 1
	;;
esac
