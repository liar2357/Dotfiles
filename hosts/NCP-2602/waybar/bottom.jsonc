{
  "layer": "top",
  "position": "bottom",

  "modules-left": [
    "custom/power",
    "custom/l-sep-power",
    "custom/luancher",
    "custom/kill",
    "custom/rotate",
    "custom/l-edge",
  ],
  "modules-center": [
    "custom/r-edge",
    "custom/ws-prev",
    "custom/r-sep",
    "hyprland/workspaces",
    "custom/l-sep",
    "custom/ws-next",
    "custom/l-edge",
  ],
  "modules-right": [
    "custom/r-edge",
    "bluetooth",
    "custom/r-sep",
    "pulseaudio",
    "custom/r-sep",
    "tray",
    "custom/r-sep",
    "custom/notify",
  ],

  // -- セパレータ --
  "custom/l-edge": {
    "format": "",
  },
  "custom/r-edge": {
    "format": "",
  },
  "custom/l-sep": {
    "format": "",
  },
  "custom/l-sep-power": {
    "format": "",
  },
  "custom/r-sep": {
    "format": "",
  },

  // --- ワークスペース/ウィンドウ (Hyprland) ---
  "hyprland/workspaces": {
    "format": "{icon} {windows}",
    "format-window-separator": " ",
    "window-rewrite-default": "",

    "window-rewrite": {
      "title<ピクチャーインピクチャー>": "󰹙",

      // Browsers (例: Vivaldi, Firefox, Chromium)
      "class<Vivaldi.*>": "󰖟",
      "class<firefox|Firefox>": "",
      "class<google-chrome>": "󰊯",

      //PWA
      "title<ChatGPT.*>": "",
      "title<YouTube.*>": "",
      "title<東映特撮ファンクラブ>": "",
      "title<Twitter>": "",
      "title<Google Keep>": "󰛜",
      "title<Google 翻訳>": "",

      // ターミナル / コンソール
      "class<org.kde.konsole|Konsole>": "",
      "class<kitty>": "",
      "class<org.wezfurlong.wezterm>": "",

      // ファイラー／ファイルマネージャ
      "class<org.kde.dolphin|dolphin>": "",
      "class<thunar>": "",

      // エディタ・IDE
      "class<code|Code|VSCodium>": "",
      "class<gedit>": "󰈙",

      // メディアプレーヤー
      "class<mpv>": "",
      "class<vlc>": "🕪",

      // コミュニケーション／チャット
      "class<com.discordapp.Discord>": "",

      // オフィスアプリ
      "class<libreoffice-startcenter>": "",
      "class<libreoffice-writer>": "",
      "class<libreoffice-calc>": "",
      "class<libreoffice-impress>": "",
      "class<libreoffice-draw>": "",
      "class<libreoffice-math>": "",
      "class<libreoffice-base>": "",
      "class<onlyoffice|ONLYOFFICE>": "󰏆",

      //メール
      "class<Thunderbird|thunderbird>": "",

      "class<com.github.xournalpp.xournalpp>": "󰽉",
      "class<guvcview|.guvcview-wrapped>": "",
    },

    // オプション：ワークスペース切替 on click
    "on-click": "activate",
    // （必要ならマウスホイールでワークスペース切替）
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
  },
  "hyprland/window": {
    "format": "{}",
  },

  // --- オーディオ (PipeWire 対応) ---
  "pulseaudio": {
    "format": " {volume}%",
    "format-muted": " muted",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
  },

  "bluetooth": {
    "format-on": " {controller_alias}",
    "format-off": "󰂲",
    "format-connected-battery": " {device_alias} ({device_battery_percentage}%)",
    "tooltip-format-connected-battery": "{device_alias} ({device_battery_percentage}%)\n{controller_alias}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_battery_percentage}%",
    "on-click": "blueman-manager",
  },

  // --- 電源メニュー ---
  "custom/power": {
    "format": "⏻",
    "tooltip-format": "Power",
    "on-click": "wlogout",
  },

  "custom/notify": {
    "format": "",
    "on-click": "swaync-client -t",
  },

  "custom/ws-next": {
    "format": "＞",
    "on-click": "hyprctl dispatch workspace r+1",
  },
  "custom/ws-prev": {
    "format": "＜",
    "on-click": "hyprctl dispatch workspace r-1",
  },

  "custom/luancher": {
    "format": "🔎",
    "on-click": "fuzzel --keyboard-focus=on-demand --no-exit-on-keyboard-focus-loss",
  },

  "custom/rotate": {
    "format": "🔄",
    "on-click": "$HOME/Dotfiles/scripts/bin/hypr-rotate",
  },

  "custom/kill": {
    "format": "❌",
    "on-click": "$HOME/Dotfiles/scripts/bin/hypr-kill",
  },
}
