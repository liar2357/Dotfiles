{
  "layer": "top",
  "position": "bottom",

  "modules-left": ["custom/luancher"],
  "modules-center": ["custom/ws-prev", "hyprland/workspaces", "custom/ws-next"],
  "modules-right": ["custom/transition", "custom/notify-count"],

  // --- ワークスペース/ウィンドウ (Hyprland) ---
  "hyprland/workspaces": {
    "format": "{icon} {windows}",
    "format-window-separator": " ",
    "window-rewrite-default": "",

    "window-rewrite": {
      //PWA
      "title<ChatGPT.*>": "🧠",
      "title<YouTube>": "▶️",
      "title<東映特撮ファンクラブ>": "🎬",
      "title<Twitter>": "",
      "title<Google Keep>": "📝",
      "title<Google 翻訳>": "🅰️",

      // Browsers (例: Vivaldi, Firefox, Chromium)
      "class<Vivaldi|vivaldi>": "",
      "class<firefox|Firefox>": "",
      "class<chromium>": "",

      // ターミナル / コンソール
      "class<org.kde.konsole|Konsole>": "",
      "class<kitty>": "",
      "class<alacritty>": "",

      // ファイラー／ファイルマネージャ
      "class<org.kde.dolphin|dolphin>": "󰉓",
      "class<thunar>": "󰉓",

      // エディタ・IDE
      "class<code|Code|VSCodium>": "",
      "class<gedit>": "󰈙",

      // メディアプレーヤー
      "class<mpv>": "",
      "class<vlc>": "🕪",

      // コミュニケーション／チャット
      "class<discord>": "",
      "class<telegram>": "",

      // オフィスアプリ
      "class<libreoffice-writer>": "",
      "class<libreoffice-calc>": "",
      "class<libreoffice-impress>": "󰐨",
      "class<onlyoffice|ONLYOFFICE>": "📄",

      //メール
      "class<Thunderbird|thunderbird>": "📧",
    },

    // オプション：ワークスペース切替 on click
    "on-click": "activate",
    // （必要ならマウスホイールでワークスペース切替）
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
  },
  "hyprland/window": {
    "format": "{}",
  },

  "custom/notify-count": {
    "format": "",
    "on-click": "kitty --title 'NotifyCenter' -e ~/.config/waybar/scripts/notify-center.sh",
  },

  "custom/ws-next": {
    "format": "＞",
    "on-click": "hyprctl dispatch workspace r+1",
  },
  "custom/ws-prev": {
    "format": "＜",
    "on-click": "hyprctl dispatch workspace r-1",
  },

  "custom/luancher": {
    "format": "🔎",
    "on-click": "fuzzel",
  },

  "custom/transition": {
    "format": "🔄",
    "on-click": "echo 'TODO!'",
  },
}
